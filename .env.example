NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Single-user app auth. Do not store the plaintext password in .env.
APP_OWNER_EMAIL=you@example.com
AUTH_PASSWORD_HASH=pbkdf2_sha256$310000$replace-with-generated-salt$replace-with-generated-hash
AUTH_SECRET=replace-with-at-least-32-random-bytes

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/auth/callback

# Phase 2 token encryption and later scheduled jobs
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
CRON_SECRET=replace-with-random-cron-secret
DEFAULT_TIMEZONE=America/Chicago
DEFAULT_GLOBAL_DAILY_SEND_CAP=70
